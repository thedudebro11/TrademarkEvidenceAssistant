{
  "name": "@trademark-evidence-assistant/server",
  "private": true,
  "version": "0.1.0",
  "description": "Express + SQLite backend for Trademark Evidence Assistant",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && node scripts/copy-migrations.mjs",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "migrate": "tsx src/db/migrate.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@trademark-evidence-assistant/shared": "*",
    "better-sqlite3": "^11.7.0",
    "express": "^4.21.2",
    "heic-decode": "^2.1.0",
    "image-size": "^1.1.1",
    "jpeg-js": "^0.4.4",
    "libheif-js": "^1.19.8",
    "pdf-lib": "^1.17.1",
    "tesseract.js": "^5.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2"
  }
}
